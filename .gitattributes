# Auto-detect text files and normalize line endings
* text=auto

# Rust source files
*.rs text diff=rust
*.toml text
*.lock text

# Shell scripts
*.sh text eol=lf

# YAML
*.yml text
*.yaml text

# Markdown
*.md text diff=markdown

# Docker
Dockerfile text

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Lock files should not be edited
Cargo.lock -diff
